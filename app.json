{
  "expo": {
    "name": "Teleprompter",
    "slug": "Teleprompter",
    "version": "1.1.0",
    "orientation": "default",
    "icon": "./assets/images/new_app_icon.png",
    "scheme": "teleprompter",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.mobile.teleprompter",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#000000",
          "image": "./assets/images/splash.png",
          "imageWidth": 200
        }
      ],
      [
        "expo-asset",
        {
          "assets": [
            "./assets/images/camera.png",
            "./assets/images/teleprompting_2.jpg",
            "./assets/images/disk.jpg",
            "./assets/images/splash.png"
          ]
        }
      ],
      [
        "expo-secure-store",
        {
          "configureAndroidBackup": true,
          "faceIDPermission": "Allow $(PRODUCT_NAME) to access your Face ID biometric data."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow $(PRODUCT_NAME) to use your camera so you can capture videos while reading your script (for example, recording a presentation with the teleprompter on screen).",
          "microphonePermission": "Allow $(PRODUCT_NAME) to use your microphone so your recorded videos include audio (for example, capturing your voice during a recording).",
          "recordAudioAndroid": true,
          "barcodeScannerEnabled": true
        }
      ],
      [
        "expo-sqlite",
        {
          "enableFTS": true,
          "useSQLCipher": true,
          "android": {
            "enableFTS": false,
            "useSQLCipher": false
          },
          "ios": {
            "customBuildFlags": [
              "-DSQLITE_ENABLE_DBSTAT_VTAB=1 -DSQLITE_ENABLE_SNAPSHOT=1"
            ]
          }
        }
      ],
      [
        "expo-file-system",
        {
          "supportsOpeningDocumentsInPlace": true,
          "enableFileSharing": true
        }
      ],
      "expo-video",
      [
        "expo-media-library",
        {
          "photosPermission": "Allow $(PRODUCT_NAME) to access your photos.",
          "savePhotosPermission": "Allow $(PRODUCT_NAME) to save photos.",
          "isAccessMediaLocationEnabled": true,
          "granularPermissions": ["audio", "photo"]
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Allow $(PRODUCT_NAME) to use the microphone.",
          "speechRecognitionPermission": "Allow $(PRODUCT_NAME) to use speech recognition."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "156f916f-a6c4-4c2d-8d28-dde4c5ccc2a9"
      }
    }
  }
}
